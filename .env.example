# ─── Required ─────────────────────────────────────────────────────────────────
# Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Email Notifications (Optional — pick one) ───────────────────────────────
# Option A: SendGrid (recommended)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Option B: SMTP (Gmail, Outlook, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password_here

# ─── Notification Config ─────────────────────────────────────────────────────
REALTOR_EMAIL=realtor@example.com
REALTOR_NAME=Your Name
FROM_EMAIL=leads@aether-realty.com

# ─── Optional ─────────────────────────────────────────────────────────────────
# Path to AETHER/Hydra engine (defaults to local dev path if not set)
# HYDRA_PATH=C:\path\to\auther\hydra

# Set to "false" in production to lock down CORS
AETHER_DEV_MODE=true

# Port (Railway sets this automatically)
PORT=8000
