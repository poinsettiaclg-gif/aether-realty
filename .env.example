# ─── Required ─────────────────────────────────────────────────────────────────
# Gemini API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Email Notifications (Optional — pick one) ───────────────────────────────
# Option A: SendGrid (recommended)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Option B: SMTP (Gmail, Outlook, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password_here

# ─── Notification Config ─────────────────────────────────────────────────────
REALTOR_EMAIL=realtor@example.com
REALTOR_NAME=Russell Roseberry
FROM_EMAIL=leads@lakeregionrealty.com

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# Required to access /leads and /leads/stats endpoints
ADMIN_API_KEY=your_admin_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Set to "true" ONLY for local development (opens CORS wildcard)
DEV_MODE=false

# Database path (defaults to lake_region_leads.db)
# DB_PATH=lake_region_leads.db

# Port (Railway/Render sets this automatically)
PORT=8000

# Production frontend URL (for CORS whitelist)
# FRONTEND_URL=https://lakeregionrealty.com
